# Base Sepolia RPC endpoint (match merchant-app-spa's VITE_RPC_URL)
RPC_URL=https://base-sepolia.g.alchemy.com/v2/mibkpQYVnBWj2Tw0lICCb

# Chain ID (Base Sepolia = 84532, Base mainnet = 8453)
CHAIN_ID=84532

# Diamond proxy address (reads + writes target this)
DIAMOND_ADDRESS=0xeb0BB8E3c014D915D9B2df03aBB130a1Fb44beb9

# thirdweb client + AA factory (match merchant-app-spa so the derived smart account
# address matches what the merchant sees in the app)
THIRDWEB_CLIENT_ID=cb8fb1375fdaa9a676723a36c1c3f530
AA_FACTORY_ADDRESS=0xde320c2e2b4953883f61774c006f9057a55b97d1

# Merchant signer keys as a comma-separated list of "CURRENCY:0xPRIVKEY" pairs.
# Each private key is the EOA signer; the bot derives the corresponding smart
# account (ERC-4337) address and uses that as the on-chain merchant identity.
# Example: MERCHANT_KEYS=INR:0xabc...,PIX:0xdef...
MERCHANT_KEYS=INR:0xREPLACE_ME

# Per-currency demo payment addresses shown to the user after accept.
# Format: CURRENCY:ADDRESS, comma-separated. Each is encrypted with the user's
# pubKey on accept, so it must match what the currency's payment method expects
# (e.g. UPI handle for INR, PIX key for BRL).
DEMO_PAYMENT_ADDRESSES=INR:p2pdemo@upi,BRL:demo@pix.br

# Poll intervals (ms)
POLL_ASSIGNED_MS=4000
POLL_ACCEPTED_MS=6000

# Optional delay before accepting a placed order (ms) so the "looking for merchant" UI shows briefly
ACCEPT_DELAY_MS=2000

# Optional delay after seeing PAID before calling completeOrder (ms)
COMPLETE_DELAY_MS=3000

# ─── Setup scripts (register-merchant / create-circle) ───────────────────────

# Admin mnemonic (super-admin + circle admin). Take this from p2p-checkout/.env
# MNEMONIC_KEY. It has Base Sepolia ETH for gas.
ADMIN_MNEMONIC=

# USDC contract address on the target chain (used to fund merchant stake)
USDC_ADDRESS=0x4095fE4f1E636f11A95820BA2bB87F335Bd1040d

# Subgraph endpoint (used to look up payment-channel configs by currency)
SUBGRAPH_URL=https://api.studio.thegraph.com/query/1745491/event-indexer/version/latest
