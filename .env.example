# ──────────────────────────────────────────────
# Megapot Checkout — Environment Variables
# ──────────────────────────────────────────────
# Copy to .env and fill in values.
# NEVER commit .env — it contains private keys.
# ──────────────────────────────────────────────

# ─── Chain & RPC ──────────────────────────────
# Base Mainnet: 8453 | Base Sepolia: 84532
CHAIN_ID=84532
RPC_URL=https://sepolia.base.org
ETHERSCAN_API_KEY=

# ─── Deployer ────────────────────────────────
# Private key of the deployer wallet (no 0x prefix)
# This wallet becomes the owner of the integrator and client contracts
DEPLOYER_PRIVATE_KEY=

# ─── Existing Protocol Addresses ─────────────
# P2P Diamond proxy address (already deployed)
DIAMOND_ADDRESS=0xeb0BB8E3c014D915D9B2df03aBB130a1Fb44beb9
# USDC token address on the target chain
USDC_ADDRESS=0x4095fE4f1E636f11A95820BA2bB87F335Bd1040d

# ─── Deployment Outputs ──────────────────────
# Filled after deployment (or hardcoded for staging)
INTEGRATOR_ADDRESS=0x...
ERC721_CLIENT_ADDRESS=0x...

# ─── Frontend (app/.env) ─────────────────────
# Privy App ID for the checkout app (from Privy dashboard)
VITE_PRIVY_APP_ID=clx...
# Chain ID for the frontend
VITE_CHAIN_ID=84532
# Diamond address for direct calls (paidBuyOrder, cancelOrder)
VITE_DIAMOND_ADDRESS=0x...
# Default integrator address (can also come from URL param)
VITE_DEFAULT_INTEGRATOR_ADDRESS=0x...

# ─── Business Onboarding ─────────────────────
# The business must set these in THEIR Privy dashboard:
#   - Whitelist our Privy App ID under "Cross-app wallets → Allowed apps"
#   - Their Privy App ID is passed as ?privyAppId= in the redirect URL
